{
  "name": "frontend",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:css\" \"npm:dev:serve\"",
    "dev:css": "tailwindcss -i ./css/tailwind.css -o ./css/tailwind.output.css --watch",
    "dev:serve": "live-server --port=5500 --entry-file=pages/login.html .",
    "build:css": "tailwindcss -i ./css/tailwind.css -o ./css/tailwind.output.css --minify"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.3",
    "concurrently": "^10.0.3",
    "live-server": "^1.2.2",
    "tailwindcss": "^4.3.3"
  }
}
